            "body": { "mode": "raw", "raw": "{\n  \"razorpayOrderId\": \"{{razorpayOrderId}}\",\n  \"razorpayPaymentId\": \"pay_ABC123XYZ\",\n  \"razorpaySignature\": \"sample_signature\",\n  \"orderId\": 1\n}" },
            "url": { "raw": "{{baseUrl}}/razorpay/verify-payment", "host": ["{{baseUrl}}"], "path": ["razorpay", "verify-payment"] }
          }
        },
        {
          "name": "Handle Failed Payment",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/razorpay/payment-failed?razorpayOrderId={{razorpayOrderId}}&reason=Payment%20failed", "host": ["{{baseUrl}}"], "path": ["razorpay", "payment-failed"], "query": [{ "key": "razorpayOrderId", "value": "{{razorpayOrderId}}" }, { "key": "reason", "value": "Payment failed" }] }
          }
        },
        {
          "name": "Get Order By Razorpay Order Id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/razorpay/order/{{razorpayOrderId}}", "host": ["{{baseUrl}}"], "path": ["razorpay", "order", "{{razorpayOrderId}}"] }
          }
        }
