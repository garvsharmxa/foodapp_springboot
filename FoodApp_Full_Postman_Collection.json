            "url": { "raw": "{{baseUrl}}/razorpay/create-order", "host": ["{{baseUrl}}"], "path": ["razorpay", "create-order"] }
          }
        },
        {
          "name": "Verify Razorpay Payment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
